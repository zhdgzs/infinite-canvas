{
    "name": "infinite-canvas-server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/index.js",
        "db:migrate": "tsx src/scripts/migrate.ts",
        "admin:reset-password": "tsx src/scripts/reset-password.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1085.0",
        "@aws-sdk/s3-request-presigner": "^3.1085.0",
        "@fastify/cookie": "^11.0.2",
        "@fastify/multipart": "^9.3.0",
        "@fastify/static": "^8.3.0",
        "argon2": "^0.44.0",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.45.1",
        "fastify": "^5.6.2",
        "file-type": "^21.1.1",
        "nanoid": "^5.1.6",
        "pg": "^8.16.3",
        "sharp": "^0.34.5",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/pg": "^8.15.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
